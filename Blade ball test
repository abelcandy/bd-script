-- ============================================================================
-- KEYBIND PARA ABRIR/FECHAR PAINEL
-- ============================================================================

local screenGui, mainPanel = nil, nil

local function SetupKeybind()
    local userInputService = game:GetService("UserInputService")
    
    userInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == CONFIG.TOGGLE_PANEL_KEY then
            if mainPanel then
                ScriptState.PanelVisible = not ScriptState.PanelVisible
                mainPanel.Visible = ScriptState.PanelVisible
            end
        end
    end)
end

-- ============================================================================
-- MAIN LOOP
-- ============================================================================

local function MainLoop()
    while true do
        SafeCall(function()
            AutoParryLogic()
            UpdateESPDrawings()
            UpdateTags()
        end)
        wait(0.1)
    end
end

-- ============================================================================
-- DETECÇÃO DE NOVOS JOGADORES
-- ============================================================================

local function SetupPlayerDetection()
    game.Players.PlayerAdded:Connect(function(player)
        wait(1) -- Aguarda o jogador carregar completamente
        if player.Character then
            local isOwner = player.Name == CONFIG.OWNER_NAME
            CreateTag(player, isOwner)
        end
    end)

    game.Players.PlayerRemoving:Connect(function(player)
        RemoveTag(player)
    end)
end

-- ============================================================================
-- INICIALIZAÇÃO
-- ============================================================================

if not game:IsLoaded() then
    game.Loaded:Wait()
end

wait(2)

print("✓ Iniciando SPY Script v5.0 (Com Sistema de Tags)...")

screenGui, mainPanel = CreateUI()

print("✓ GUI criada com sucesso!")
print("✓ Sistema de Tags Flutuantes ativo")
print("✓ Owner: " .. CONFIG.OWNER_NAME .. " (RGB)")
print("✓ Keybind: Pressione 'B' para abrir/fechar")

SetupKeybind()
SetupPlayerDetection()

task.spawn(MainLoop)

print("✓ Death Ball Script v5.0 carregado com sucesso!")

game.Players.LocalPlayer.CharacterAdded:Connect(function()
    CleanupESP()
end)
