local function CreateTag(player, isOwner)
    SafeCall(function()
        local character = player.Character
        if not character then return end

        local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
        if not humanoidRootPart then return end

        -- Criar BillboardGui para a tag
        local billboardGui = Instance.new("BillboardGui")
        billboardGui.Name = "TagBillboard_" .. player.Name
        billboardGui.Size = UDim2.new(4, 0, 2, 0)
        billboardGui.StudsOffset = Vector3.new(0, CONFIG.TAG_OFFSET_Y, 0)
        billboardGui.MaxDistance = CONFIG.TAG_DISTANCE
        billboardGui.Parent = humanoidRootPart

        -- Criar TextLabel para a tag
        local tagLabel = Instance.new("TextLabel")
        tagLabel.Name = "TagLabel"
        tagLabel.Size = UDim2.new(1, 0, 1, 0)
        tagLabel.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        tagLabel.BackgroundTransparency = 0.1
        tagLabel.BorderSizePixel = 2
        tagLabel.BorderColor3 = Color3.fromRGB(100, 100, 100)
        tagLabel.Font = Enum.Font.GothamBold
        tagLabel.TextSize = CONFIG.TAG_SIZE
        tagLabel.Parent = billboardGui

        if isOwner then
            tagLabel.Text = "👑 OWNER"
            tagLabel.TextColor3 = GetRGBColor(0)
        else
            tagLabel.Text = "👤 USER"
            tagLabel.TextColor3 = CONFIG.TEXT_COLOR
        end

        -- Adicionar UICorner para estilo arredondado
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = tagLabel

        table.insert(ScriptState.TagObjects, {
            Billboard = billboardGui,
            Label = tagLabel,
            Player = player,
            IsOwner = isOwner
        })

        return billboardGui
    end)
end

local function RemoveTag(player)
    SafeCall(function()
        for idx, tag in ipairs(ScriptState.TagObjects) do
            if tag.Player == player then
                tag.Billboard:Destroy()
                table.remove(ScriptState.TagObjects, idx)
                break
            end
        end
    end)
end

local function UpdateTags()
    if not ScriptState.TagsEnabled then
        for _, tag in ipairs(ScriptState.TagObjects) do
            tag.Billboard.Enabled = false
        end
        return
    end

    SafeCall(function()
        local localPlayer = GetLocalPlayer()
        local localCharacter = GetLocalCharacter()

        if not localCharacter then return end

        -- Verificar cada tag existente
        for idx, tag in ipairs(ScriptState.TagObjects) do
            if not tag.Player or not tag.Player.Parent then
                -- Jogador saiu do jogo
                tag.Billboard:Destroy()
                table.remove(ScriptState.TagObjects, idx)
            else
                -- Atualizar visibilidade
                tag.Billboard.Enabled = true

                -- Atualizar cor RGB para Owner
                if tag.IsOwner then
                    ScriptState.RGBValue = (ScriptState.RGBValue + 0.05) % (2 * math.pi)
                    tag.Label.TextColor3 = GetRGBColor(ScriptState.RGBValue)
                end
            end
        end

        -- Criar tags para novos jogadores
        for _, player in pairs(game.Players:GetPlayers()) do
            if player ~= localPlayer and player.Character then
                local existingTag = false
                for _, tag in ipairs(ScriptState.TagObjects) do
                    if tag.Player == player then
                        existingTag = true
                        break
                    end
                end

                if not existingTag then
                    -- Verificar se é o owner
                    local isOwner = player.Name == CONFIG.OWNER_NAME
                    CreateTag(player, isOwner)
                end
            end
        end
    end)
end

-- ============================================================================
-- DETECÇÃO DE BOLAS E AUTO PARRY
-- ============================================================================

local function DetectIncomingBalls()
    local detectedBalls = {}
    
    SafeCall(function()
        local character = GetLocalCharacter()
        if not character then return end
        
        local hrp = GetHumanoidRootPart()
        if not hrp then return end

        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                local name = obj.Name:lower()
                
                if name:match("ball") or name:match("death") or name:match("projectile") then
                    local distance = (obj.Position - hrp.Position).Magnitude
                    
                    if distance <= CONFIG.BALL_DETECTION_RANGE then
                        if obj:FindFirstChild("BodyVelocity") or obj.Velocity.Magnitude > 1 then
                            table.insert(detectedBalls, {
                                Object = obj,
                                Distance = distance,
                                Velocity = obj.Velocity,
                            })
                        end
                    end
                end
            end
        end
    end)

    table.sort(detectedBalls, function(a, b) return a.Distance < b.Distance end)
    return detectedBalls
end

local function ShouldParry(ball)
    if not ball then return false end
    
    local hrp = GetHumanoidRootPart()
    if not hrp then return false end

    local ballToPlayer = hrp.Position - ball.Object.Position
    local ballVelocity = ball.Object.Velocity
    
    if ballVelocity.Magnitude == 0 then return false end
    
    local ballDirection = ballVelocity.Unit
    local ballDirAlignment = ballToPlayer.Unit:Dot(ballDirection)
    
    return ballDirAlignment > 0.3
end

local function PerformParry()
    SafeCall(function()
        local currentTime = tick()
        if currentTime - ScriptState.LastParryTime < CONFIG.PARRY_COOLDOWN then
            return
        end

        keypress(string.byte("f"))
        
        ScriptState.LastParryTime = currentTime
        ScriptState.ParryAttempts = ScriptState.ParryAttempts + 1
    end)
end

local function AutoParryLogic()
    if not ScriptState.AutoParryEnabled then return end

    SafeCall(function()
        local character = GetLocalCharacter()
        if not character or not GetHumanoidRootPart() then return end

        local detectedBalls = DetectIncomingBalls()
        
        if #detectedBalls > 0 then
            local closestBall = detectedBalls[1]
            if ShouldParry(closestBall) then
                PerformParry()
            end
        end
    end)
end

